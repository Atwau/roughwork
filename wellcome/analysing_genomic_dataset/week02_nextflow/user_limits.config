process {
    // This rule applies to EVERY task in the pipeline
    withName: '.*' {
        cpus   = 2
        memory = '12 GB'
        maxForks = 1
    }

    // This specifically targets the task that just failed (BLAST_MAKEBLASTDB)
    // and any other high-memory indexing tasks.
    withName: 'BLAST_MAKEBLASTDB|SNPEFF_BUILD|BOWTIE2_BUILD' {
        memory = '12 GB'
        cpus = 2
    }

    // ADD THIS BLOCK: It allows the pipeline to finish even if R plots fail
    withName: 'PLOT_BASE_DENSITY' {
        errorStrategy = 'ignore'
    }
}
